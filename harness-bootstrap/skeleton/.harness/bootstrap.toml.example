bootstrap_version = "0.2.0"
mode = "greenfield"
preset = "none"
entry_skill = "harness:init"
governance_model = "harness-governance-only.v1"
templates_dir = "docs/superpowers/templates"
doc_health_skill = "harness:doc-health"
lint_test_skill = "harness:lint-test-design"

[governance.refactor_route]
preferred = true
path_hints = [
  "*/composition*",
  "*/workflow*",
  "*/shell*",
]
change_kinds = [
  "create",
  "move",
  "rename",
  "ownership-change",
  "boundary-surface",
]

[governance.refactor_gate]
enabled = false
trigger = "commit"
mode = "review"
subagent_first = true
path_rules = []
artifact_dir = "superpowers/artifacts/refactor-gate"

[governance.lint_test_route]
preferred = true
intents = [
  "coverage policy",
  "file-role rules",
  "guardrail design",
  "invariant design",
]
finding_hints = [
  "recurring-boundary-finding",
  "mechanizable-edge",
  "coverage-gap",
  "exception-ratchet",
]
